generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  DRAFT
  PUBLISHED
  DELETED
}

model Field {
  id        Int     @id @default(autoincrement())
  label     String
  type      String
  conditions Json?
  order     Int
  formId    Int
  form      Form    @relation(fields: [formId], references: [id])
}

model Form {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  order       Int
  fields      Field[]
  status      Status  @default(DRAFT)
  ownerId     Int
}